@page
@model 프로젝트관리.Pages.Attendance.IndexModel
@using 프로젝트관리.Models
@{
    ViewData["Title"] = "참석";
    var isEdit = Model.EditId.HasValue;
    var showRegistrationPanel = isEdit || !ViewData.ModelState.IsValid;
    string BadgeClass(AttendanceStatus status) => status switch
    {
        AttendanceStatus.Attended => "badge bg-success",
        AttendanceStatus.Absent => "badge bg-danger",
        _ => "badge bg-light text-dark"
    };
    string StatusText(AttendanceStatus status) => status switch
    {
        AttendanceStatus.Attended => "참석",
        AttendanceStatus.Absent => "결석",
        _ => status.ToString()
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">참석 관리</h3>
    <span class="text-muted small">총 @Model.Items.Count 건</span>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card">
            <div class="card-header">참석 목록</div>
            <div class="card-body table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>세션</th>
                            <th>이름</th>
                            <th>부서</th>
                            <th>상태</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Session?.SessionDate @item.Session?.Class?.ClassName</td>
                            <td>@item.UserName</td>
                            <td>@item.Department</td>
                            <td><span class="@BadgeClass(item.AttendanceStatus)">@StatusText(item.AttendanceStatus)</span></td>
                            <td>
                                <a asp-page="/Attendance/Index" asp-route-editId="@item.AttendanceId" class="btn btn-outline-primary btn-sm">수정</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="5" class="text-center text-muted py-4">참석 데이터가 없습니다.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">@(isEdit ? "참석 수정" : "참석 등록")</span>
                @if (!showRegistrationPanel)
                {
                    <button type="button" class="btn btn-primary btn-sm rounded-circle d-inline-flex align-items-center justify-content-center"
                            style="width:2.25rem;height:2.25rem;padding:0;"
                            data-bs-toggle="collapse" data-bs-target="#attendanceRegCollapse"
                            aria-expanded="false" aria-controls="attendanceRegCollapse" title="등록 폼 열기">
                        +
                    </button>
                }
            </div>
            <div id="attendanceRegCollapse" class="collapse @(showRegistrationPanel ? "show" : "")">
            <div class="card-body">
                <form method="post" asp-page-handler="@(isEdit ? "Edit" : "Create")">
                    <input type="hidden" asp-for="Input.AttendanceId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-2">
                        <label asp-for="Input.SessionId" class="form-label"></label>
                        <select asp-for="Input.SessionId" asp-items="Model.SessionOptions" class="form-select"></select>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Input.UserName" class="form-label"></label>
                        <input asp-for="Input.UserName" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label asp-for="Input.Department" class="form-label"></label>
                        <input asp-for="Input.Department" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="Input.AttendanceStatus" class="form-label"></label>
                        <select asp-for="Input.AttendanceStatus" asp-items="Html.GetEnumSelectList<AttendanceStatus>()" class="form-select"></select>
                    </div>
                    <button class="btn btn-primary" type="submit">저장</button>
                    <a asp-page="/Attendance/Index" class="btn btn-outline-secondary">초기화</a>
                </form>
            </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
