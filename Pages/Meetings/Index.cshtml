@page
@model 프로젝트관리.Pages.Meetings.IndexModel
@using 프로젝트관리.Models
@{
    ViewData["Title"] = "회의";
    var meetingEdit = Model.EditMeetingId.HasValue;
    string MeetingTypeBadge(MeetingType type) => type switch
    {
        MeetingType.Regular => "badge bg-primary",
        MeetingType.Adhoc => "badge bg-warning text-dark",
        MeetingType.Urgent => "badge bg-danger",
        _ => "badge bg-light text-dark"
    };
    string MeetingTypeText(MeetingType type) => type switch
    {
        MeetingType.Regular => "정기",
        MeetingType.Adhoc => "수시",
        MeetingType.Urgent => "긴급",
        _ => type.ToString()
    };
}

<h3 class="mb-3">회의 관리</h3>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card mb-3">
            <div class="card-header">회의 목록</div>
            <div class="card-body table-responsive">
                <table class="table table-sm table-hover">
                    <thead>
                        <tr>
                            <th>일자</th>
                            <th>회의명</th>
                            <th>유형</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Meetings)
                    {
                        <tr>
                            <td>@item.MeetingDate</td>
                            <td>@item.MeetingName</td>
                            <td><span class="@MeetingTypeBadge(item.MeetingType)">@MeetingTypeText(item.MeetingType)</span></td>
                            <td>
                                <a asp-page="/Meetings/Index" asp-route-editMeetingId="@item.MeetingId" class="btn btn-outline-primary btn-sm">수정</a>
                                <a asp-page="/Agendas/Index" asp-route-meetingFilterId="@item.MeetingId" class="btn btn-outline-secondary btn-sm">안건 보기</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Meetings.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">등록된 회의가 없습니다.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card">
            <div class="card-header">@(meetingEdit ? "회의 수정" : "회의 등록")</div>
            <div class="card-body">
                <form method="post" asp-page-handler="@(meetingEdit ? "EditMeeting" : "CreateMeeting")">
                    <input type="hidden" asp-for="MeetingInput.MeetingId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-2">
                        <label asp-for="MeetingInput.MeetingDate" class="form-label"></label>
                        <input asp-for="MeetingInput.MeetingDate" class="form-control" />
                    </div>
                    <div class="mb-2">
                        <label asp-for="MeetingInput.MeetingName" class="form-label"></label>
                        <input asp-for="MeetingInput.MeetingName" class="form-control" />
                    </div>
                    <div class="mb-3">
                        <label asp-for="MeetingInput.MeetingType" class="form-label"></label>
                        <select asp-for="MeetingInput.MeetingType" asp-items="Html.GetEnumSelectList<MeetingType>()" class="form-select"></select>
                    </div>
                    <button class="btn btn-primary" type="submit">저장</button>
                    <a asp-page="/Meetings/Index" class="btn btn-outline-secondary">초기화</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
