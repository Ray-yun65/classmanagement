<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - 프로젝트관리</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/프로젝트관리.styles.css" asp-append-version="true" />
</head>
<body>
    <header class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">
        <div class="container-fluid px-4">
            <a class="navbar-brand fw-semibold" asp-page="/Index">교육 운영 관리</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav" aria-controls="mainNav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto gap-1">
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-page="/Index">대시보드</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-page="/Classes/Index">교육과정</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-page="/Sessions/Index">세션</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-page="/Attendance/Index">참석</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-page="/Meetings/Index">회의</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-white" asp-page="/Agendas/Index">안건</a>
                    </li>
                </ul>
            </div>
        </div>
    </header>
    <div class="container-fluid px-4 py-4">
        <main role="main" class="bg-light rounded-3 p-3 p-md-4">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>