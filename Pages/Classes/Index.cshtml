@page
@model 프로젝트관리.Pages.Classes.IndexModel
@using 프로젝트관리.Models
@{
    ViewData["Title"] = "교육과정";
    var isEdit = Model.EditId.HasValue;
    var showRegistrationPanel = isEdit || !ViewData.ModelState.IsValid;
    string BadgeClass(ClassStatus status) => status switch
    {
        ClassStatus.Planned => "badge bg-secondary",
        ClassStatus.Ongoing => "badge bg-primary",
        ClassStatus.Completed => "badge bg-success",
        _ => "badge bg-light text-dark"
    };
    string StatusText(ClassStatus status) => status switch
    {
        ClassStatus.Planned => "계획",
        ClassStatus.Ongoing => "진행",
        ClassStatus.Completed => "완료",
        _ => status.ToString()
    };
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h3 class="mb-0">교육과정 관리</h3>
    <span class="text-muted small">총 @Model.Items.Count 건</span>
</div>

<div class="row g-4">
    <div class="col-lg-7">
        <div class="card">
            <div class="card-header">교육과정 목록</div>
            <div class="card-body table-responsive">
                <table class="table table-sm table-hover align-middle">
                    <thead>
                        <tr>
                            <th>과정명</th>
                            <th>대상 부서</th>
                            <th>상태</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.ClassName</td>
                            <td>@item.TargetDepartment</td>
                            <td><span class="@BadgeClass(item.Status)">@StatusText(item.Status)</span></td>
                            <td>
                                <a asp-page="/Classes/Index" asp-route-editId="@item.ClassId" class="btn btn-outline-primary btn-sm">수정</a>
                            </td>
                        </tr>
                    }
                    @if (!Model.Items.Any())
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4">등록된 과정이 없습니다.</td></tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
    <div class="col-lg-5">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <span class="fw-semibold">@(isEdit ? "교육과정 수정" : "교육과정 등록")</span>
                @if (!showRegistrationPanel)
                {
                    <button type="button" class="btn btn-primary btn-sm rounded-circle d-inline-flex align-items-center justify-content-center"
                            style="width:2.25rem;height:2.25rem;padding:0;"
                            data-bs-toggle="collapse" data-bs-target="#classRegCollapse"
                            aria-expanded="false" aria-controls="classRegCollapse" title="등록 폼 열기">
                        +
                    </button>
                }
            </div>
            <div id="classRegCollapse" class="collapse @(showRegistrationPanel ? "show" : "")">
            <div class="card-body">
                <form method="post" asp-page-handler="@(isEdit ? "Edit" : "Create")">
                    <input type="hidden" asp-for="Input.ClassId" />
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                    <div class="mb-2">
                        <label asp-for="Input.ClassName" class="form-label"></label>
                        <input asp-for="Input.ClassName" class="form-control" />
                        <span asp-validation-for="Input.ClassName" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Input.TargetDepartment" class="form-label"></label>
                        <input asp-for="Input.TargetDepartment" class="form-control" />
                        <span asp-validation-for="Input.TargetDepartment" class="text-danger"></span>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Input.Status" class="form-label"></label>
                        <select asp-for="Input.Status" asp-items="Html.GetEnumSelectList<ClassStatus>()" class="form-select"></select>
                    </div>
                    <div class="mb-2">
                        <label asp-for="Input.Description" class="form-label"></label>
                        <textarea asp-for="Input.Description" class="form-control" rows="3" placeholder="과정 설명, 운영 메모"></textarea>
                    </div>
                    <button class="btn btn-primary" type="submit">저장</button>
                    <a asp-page="/Classes/Index" class="btn btn-outline-secondary">초기화</a>
                </form>
            </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
